---
// src/layouts/Layout.astro
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';


interface Props {
	title: string;
}

const { title } = Astro.props;
---


<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/Ariful-Hasan/favicon.svg" />
		
		<title>Ariful Hasan | Senior Full-Stack Software Developer in Berlin</title>
		<meta name="title" content="Ariful Hasan | Senior Full-Stack Software Developer" />
		<meta name="description" content="Senior Software Developer based in Berlin, Germany. Expert in PHP 8.4, Node.js, Microservices, and Fintech solutions. Lead developer for CashToCode at Funanga." />

		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://ariful-hasan.github.io/Ariful-Hasan/" />
		<meta property="og:title" content="Ariful Hasan | Senior Software Developer" />
		<meta property="og:description" content="Building scalable Fintech and SaaS solutions with PHP, Node.js, and AWS." />
		<meta property="og:image" content="https://ariful-hasan.github.io/Ariful-Hasan/og-image.png" />

		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:title" content="Ariful Hasan | Senior Software Developer" />
	</head>
	<body class="bg-slate-950 text-slate-200">
		<Navbar />
		<slot /> 
		<Footer />
	</body>
</html>
