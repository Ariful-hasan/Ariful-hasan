---
import { SITE_DATA } from '../data/config';

const skillCategories = SITE_DATA.Skills;
---

<section id="skills" class="py-24 max-w-6xl mx-auto px-6">
  <p class="text-xs font-mono text-blue-500 uppercase tracking-widest mb-2">Expertise</p>
  <h2 class="text-4xl font-bold text-white mb-12">Tech Stack & <span class="text-cyan-400">Skills</span></h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    {skillCategories.map((cat) => (
      <div class="bg-[#0f172a]/50 border border-slate-800 p-8 rounded-xl hover:border-slate-700 transition-colors">
        <h3 class={`text-xs font-bold tracking-widest mb-6 ${cat.color}`}>{cat.title}</h3>
        <ul class="space-y-3">
          {cat.skills.map(skill => (
            <li class="text-slate-400 text-sm">{skill}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
  <div class="mt-16 pt-12 border-t border-slate-900 grid grid-cols-1 md:grid-cols-3 gap-8">
  <div class="space-y-2">
    <h4 class="text-white font-bold text-sm uppercase tracking-wider">Methodologies</h4>
    <p class="text-slate-400 text-xs leading-relaxed">
      Adhering to **SOLID** principles, **DDD (Domain-Driven Design)**, and **TDD** to ensure maintainable and testable codebases.
    </p>
  </div>
  <div class="space-y-2">
    <h4 class="text-white font-bold text-sm uppercase tracking-wider">Security First</h4>
    <p class="text-slate-400 text-xs leading-relaxed">
      Implementing secrets management via **HashiCorp Vault** and ensuring **GDPR compliance** in high-availability Fintech environments.
    </p>
  </div>
  <div class="space-y-2">
    <h4 class="text-white font-bold text-sm uppercase tracking-wider">Strategic AI</h4>
    <p class="text-slate-400 text-xs leading-relaxed">
      Leveraging **Cursor AI** and LLMs for rapid prototyping, complex refactoring, and 30% faster deployment cycles.
    </p>
  </div>
</div>
</section>